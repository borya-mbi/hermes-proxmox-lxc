# Force LF line endings for all text files used on Linux
*.sh            text eol=lf
*.env           text eol=lf
*.env.example   text eol=lf
*.service       text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
*.md            text eol=lf
*.tsv           text eol=lf
*.conf          text eol=lf
*.tpl           text eol=lf
Makefile        text eol=lf
