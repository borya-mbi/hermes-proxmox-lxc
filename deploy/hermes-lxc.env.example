# deploy-hermes v2: Multi-user модель.
# Один LXC-контейнер, кілька Linux-користувачів, кожен зі своїм інстансом Hermes.
#
# Перед реальним запуском замініть IP, домени, ідентифікатори форку
# під свою інфраструктуру.
# ── Користувачі Hermes ──────────────────────────────────
# Prod-користувачі використовують PROD_BRANCH вашого форку.
# Dev-користувач використовує DEV_BRANCH гілку для тестування.
HERMES_PROD_USERS="user1 user2"
HERMES_DEV_USERS="dev-user"
# ── Git Fork ─────────────────────────────────────────────
# Власний форк NousResearch/hermes-agent.
# Prod отримує чисту реінсталяцію з main.
# Dev працює через інсталяційний скрипт (з гілки custom-features).
HERMES_FORK_OWNER=your-github-username
HERMES_FORK_REPO=hermes-agent
HERMES_PROD_BRANCH=main
HERMES_DEV_BRANCH=custom-features
# ── Claude Code ──────────────────────────────────────────
# Встановити Claude Code per-user через npm.
# Після bootstrap потрібен ручний крок: su - <user> -c 'claude login'
INSTALL_CLAUDE_CODE=true
# ── Контейнер-шаблон і базові параметри Proxmox ─────────
TEMPLATE_CTID=9300
TEMPLATE_IMAGE=local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst
STORAGE=local-lvm
TEMPLATE_IP=.250
BRIDGE=vmbr1
VLAN_TAG=
HOST_WAN_IF=vmbr0
HOST_PUBLIC_IP=203.0.113.12
# ── Приватна мережа контейнерів ──────────────────────────
PRIVATE_SUBNET_CIDR=192.168.10.0/24
PRIVATE_GATEWAY=192.168.10.1
PRIVATE_PREFIX_LENGTH=24
STATIC_IP_PREFIX=192.168.10
STATIC_IP_START=31
IP_CONFIG=static
CT_DHCP_TIMEOUT=120
# ── Контейнер Nginx Proxy Manager ────────────────────────
NPM_LXC_IP=192.168.10.10
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81
# ── Доменна схема ────────────────────────────────────────
BASE_DOMAIN=example.com
PRIMARY_PUBLIC_DOMAIN=agent.example.com
PORTAL_CTID=930
PRIMARY_PUBLIC_CTID=931
NPM_ADMIN_DOMAIN=npm.example.com
ADMIN_DOMAIN_PREFIX=adm
AGENT_DOMAIN_PREFIX=agent
# HERMES_PUBLIC_PORT та HERMES_ADMIN_PORT більше не задаються тут.
# Вони обчислюються як HERMES_BASE_PORT + user_index (див. нижче).
HERMES_HTTP_HEALTH_PATH=/
# ── Порядок розгортання ──────────────────────────────────
START_CTID=931
COUNT=1
NAME_PREFIX=hermes
# ── Порти для Multi-user (базові значення для інкременту) ─
# Кожен наступний користувач у контейнері отримає порт +1
HERMES_BASE_PORT=8080
HERMES_ADMIN_BASE_PORT=9080
# ── Ресурси контейнера (збільшені для multi-user) ────────
CT_MEMORY=4096
CT_SWAP=1024
CT_CORES=4
CT_ROOTFS_SIZE=16
CT_UNPRIVILEGED=1
CT_ONBOOT=1
TIMEZONE=Europe/Kyiv
# ── Локальні файли і звіти ───────────────────────────────
LOCAL_HERMES_USER_ENV_FILE=deploy/hermes-user.env
LOCAL_CONFIG_YAML_FILE=deploy/config.yaml
SYSTEMD_SERVICE_FILE=systemd/hermes-agent@.service
PORT_FORWARD_FILE=deploy/port-forwards.tsv
NPM_PROXY_HOSTS_FILE=deploy/npm-proxy-hosts.tsv
CONTAINER_INFO_FILE=deploy/container_info.tsv
FAILED_CTIDS_FILE=deploy/failed_ctids.txt
NOTES_FILE=deploy/container-notes.tsv
AUTHORIZED_KEYS_FILE=deploy/authorized_keys
STORAGE_FREE_BUFFER_GB=2
DRY_RUN=1
# ── Hermes service name ─────────────────────────────────
HERMES_SERVICE_NAME=hermes-agent
# ── Базові пакети для контейнера ─────────────────────────
HERMES_APT_PACKAGES="git curl ca-certificates sudo build-essential gettext"
