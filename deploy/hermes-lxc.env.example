# Proxmox / LXC
TEMPLATE_CTID=9300
TEMPLATE_IMAGE=local:vztmpl/debian-12-standard_12.7-1_amd64.tar.zst
STORAGE=local-lvm
BRIDGE=vmbr1
VLAN_TAG=
HOST_WAN_IF=vmbr0
HOST_PUBLIC_IP=203.0.113.1
PRIVATE_SUBNET_CIDR=192.168.10.0/24
PRIVATE_GATEWAY=192.168.10.1
PRIVATE_PREFIX_LENGTH=24
STATIC_IP_PREFIX=192.168.10
STATIC_IP_START=31
NPM_LXC_IP=192.168.10.10
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81
BASE_DOMAIN=yourdomain.com
PRIMARY_PUBLIC_DOMAIN=agent.yourdomain.com
PORTAL_CTID=930
PRIMARY_PUBLIC_CTID=931
NPM_ADMIN_DOMAIN=npm.yourdomain.com
ADMIN_DOMAIN_PREFIX=adm
AGENT_DOMAIN_PREFIX=agent
HERMES_PUBLIC_PORT=8080
HERMES_ADMIN_PORT=8081
HERMES_HTTP_HEALTH_PATH=/
START_CTID=931
COUNT=1
NAME_PREFIX=hermes
CT_MEMORY=2048
CT_SWAP=512
CT_CORES=2
CT_ROOTFS_SIZE=8
CT_UNPRIVILEGED=1
CT_ONBOOT=1
CT_DHCP_TIMEOUT=120
IP_CONFIG=static
TIMEZONE=Europe/Kyiv

# Tracking / reporting
LOCAL_HERMES_ENV_FILE=deploy/hermes.env
SYSTEMD_TEMPLATE_FILE=systemd/hermes-agent.service.tpl
PORT_FORWARD_FILE=deploy/port-forwards.tsv
NPM_PROXY_HOSTS_FILE=deploy/npm-proxy-hosts.tsv
CONTAINER_INFO_FILE=deploy/container_info.tsv
FAILED_CTIDS_FILE=deploy/failed_ctids.txt
NOTES_FILE=deploy/container-notes.tsv
AUTHORIZED_KEYS_FILE=deploy/authorized_keys
STORAGE_FREE_BUFFER_GB=2
DRY_RUN=1

# Hermes inside container
HERMES_SERVICE_NAME=hermes-agent
HERMES_RUN_USER=hermes
HERMES_RUN_GROUP=hermes
HERMES_APP_DIR=/opt/hermes-agent
HERMES_CONFIG_DIR=/etc/hermes
HERMES_STATE_DIR=/var/lib/hermes
HERMES_LOG_DIR=/var/log/hermes
HERMES_ENV_FILE=/etc/hermes/hermes.env
HERMES_APT_PACKAGES=git curl ca-certificates python3 python3-venv python3-pip
HERMES_REPO_URL=https://example.com/your-org/hermes.git
HERMES_REPO_REF=main
HERMES_GIT_DEPTH=1
HERMES_INSTALL_CMD=python3 -m venv .venv && . .venv/bin/activate && pip install --upgrade pip && if [ -f requirements.txt ]; then pip install -r requirements.txt; fi
HERMES_START_CMD=/opt/hermes-agent/.venv/bin/python -m hermes
HERMES_AFTER_START_CMD=
HERMES_HEALTHCHECK_CMD=systemctl is-active hermes-agent
