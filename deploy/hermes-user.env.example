# Per-user env для Hermes Agent.
# Кожен користувач отримує свою копію цього файлу у ~/.hermes/.env при bootstrap.
# Секрети не комітьте у git.

# Основний API ключ (OpenRouter як fallback)
OPENAI_API_KEY=sk-or-v1-replace-me
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Telegram
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_ALLOWED_USER_IDS=replace-me

# Per-user Telegram channel ID (використовується у config.yaml через envsubst)
TG_CHANNEL_ID=replace-me

# Claude Code (якщо встановлено)
ANTHROPIC_API_KEY=replace-me

# Google/Gemini keys for config.yaml providers
GOOGLE_API_KEY_1=
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
